{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "moonfind.provider-use-decision.v1",
  "type": "object",
  "required": ["contract_id", "provider_id", "use_case", "decision", "reasons", "terms_ref"],
  "properties": {
    "contract_id": {"const": "moonfind.provider-use-decision.v1"},
    "provider_id": {"type": "string", "minLength": 1},
    "use_case": {"type": "string", "minLength": 1},
    "decision": {"enum": ["allow", "deny"]},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "terms_ref": {"type": "string"}
  },
  "additionalProperties": true
}
